# =============================================================
#  Activités Melun — Fichier de configuration d'environnement
#  Copiez ce fichier en ".env" et remplissez les valeurs
#  cp .env.example .env
# =============================================================

# -------------------------------------------------------------
# Base de données MySQL
# -------------------------------------------------------------
DB_HOST=localhost
DB_NAME=opendatav2
DB_USER=root
DB_PASSWORD=

# -------------------------------------------------------------
# PHPMailer — Configuration SMTP (optionnel)
# Nécessaire uniquement si vous activez les notifications email
# -------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=votre@email.com
MAIL_PASSWORD=votre_mot_de_passe_app
MAIL_FROM_NAME=Activités Melun
